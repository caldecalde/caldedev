---
import { profile } from "../data/profile";
---

<section id="about" class="mx-auto max-w-4xl scroll-mt-24 px-6 py-16">
  <h2 class="mb-8 flex items-center gap-3 text-2xl font-bold text-white">
    <span class="font-mono text-lg text-indigo-400">01.</span>
    Sobre mí
  </h2>

  <div class="space-y-4 text-slate-400 leading-relaxed">
    {profile.bio.map((paragraph) => <p>{paragraph}</p>)}
  </div>
</section>
