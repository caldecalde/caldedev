---
import { profile } from "../data/profile";
---

<section class="relative mx-auto flex max-w-4xl flex-col items-start gap-6 px-6 pb-24 pt-20 sm:pt-32">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[28rem] bg-[radial-gradient(ellipse_at_top,_rgba(99,102,241,0.18),_transparent_65%)]"
  >
  </div>

  <p class="font-mono text-sm text-indigo-400">Hola, mi nombre es</p>
  <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
    {profile.name}
  </h1>
  <h2 class="text-2xl font-semibold text-slate-400 sm:text-3xl">
    {profile.title}
  </h2>
  <p class="max-w-xl text-slate-400">
    {profile.tagline}
  </p>

  <div class="mt-4 flex flex-wrap gap-4">
    <a
      href="#projects"
      class="rounded-md border border-indigo-400/40 bg-indigo-500/10 px-5 py-2.5 text-sm font-medium text-indigo-300 transition-colors hover:bg-indigo-500/20"
    >
      Ver proyectos
    </a>
    <a
      href="#contact"
      class="rounded-md border border-white/10 px-5 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:border-white/20 hover:text-white"
    >
      Contáctame
    </a>
  </div>
</section>
