---
import { profile } from "../data/profile";
---

<section id="contact" class="mx-auto max-w-4xl scroll-mt-24 px-6 py-16 text-center">
  <h2 class="mb-4 font-mono text-sm text-indigo-400">03. Contacto</h2>
  <h3 class="text-3xl font-bold text-white sm:text-4xl">¿Hablamos?</h3>
  <p class="mx-auto mt-4 max-w-md text-slate-400">
    Estoy abierto a nuevas oportunidades y colaboraciones. Escríbeme y con
    gusto conversamos.
  </p>

  <a
    href={`mailto:${profile.email}`}
    class="mt-8 inline-block rounded-md border border-indigo-400/40 bg-indigo-500/10 px-6 py-3 text-sm font-medium text-indigo-300 transition-colors hover:bg-indigo-500/20"
  >
    Escribir a {profile.email}
  </a>
</section>
